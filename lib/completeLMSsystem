class _ManageAssignmentsPageState extends State<ManageAssignmentsPage> {
  final NotificationService notificationService = NotificationService();

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text('Assignments')),
      body: ListView.builder(
        itemCount: DataManager.assignments.length,
        itemBuilder: (context, index) {
          final assignment = DataManager.assignments[index];
          return Card(
            margin: EdgeInsets.all(8),
            child: ExpansionTile(
              title: Text(assignment.title),
              subtitle: Text('Due: ${DateFormat('MMM dd, yyyy').format(assignment.dueDate)} | Total: ${assignment.totalMarks}'),
              children: [
                Padding(
                  padding: EdgeInsets.all(16),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Text('Description: ${assignment.description}'),
                      SizedBox(height: 8),
                      Text('Marks:', style: TextStyle(fontWeight: FontWeight.bold)),
                      ...DataManager.students.map((student) => ListTile(
                        title: Text(student.name),
                        trailing: SizedBox(
                          width: 100,
                          child: TextField(
                            decoration: InputDecoration(
                              labelText: 'Marks',
                              border: OutlineInputBorder(),
                            ),
                            keyboardType: TextInputType.number,
                            onSubmitted: (value) {
                              final marks = int.tryParse(value) ?? 0;
                              DataManager.updateAssignmentMarks(assignment.id, student.id, marks);
                              notificationService.showNotification(
                                'Marks Updated 📝',
                                '${student.name} scored $marks in ${assignment.title}',
                              );
                              setState(() {});
                            },
                          ),
                        ),
                      )).toList(),
                    ],
                  ),
                ),
              ],
            ),
          );
        },
      ),
      floatingActionButton: FloatingActionButton(
        onPressed: _createAssignment,
        child: Icon(Icons.add),
        tooltip: 'Create Assignment',
      ),
    );
  }

  void _createAssignment() async {
    final titleController = TextEditingController();
    final descController = TextEditingController();
    DateTime? dueDate;

    await showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: Text('Create Assignment'),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            TextField(
              controller: titleController,
              decoration: InputDecoration(labelText: 'Title'),
            ),
            TextField(
              controller: descController,
              decoration: InputDecoration(labelText: 'Description'),
              maxLines: 3,
            ),
            ListTile(
              title: Text(dueDate == null ? 'Select Due Date' : DateFormat('MMM dd, yyyy').format(dueDate!)),
              trailing: Icon(Icons.calendar_today),
              onTap: () async {
                final date = await showDatePicker(
                  context: context,
                  initialDate: DateTime.now(),
                  firstDate: DateTime.now(),
                  lastDate: DateTime.now().add(Duration(days: 365)),
                );
                if (date != null) {
                  dueDate = date;
                  setState(() {});
                }
              },
            ),
          ],
        ),
        actions: [
          TextButton(onPressed: () => Navigator.pop(context), child: Text('Cancel')),
          ElevatedButton(
            onPressed: () {
              final assignment = Assignment(
                id: DateTime.now().millisecondsSinceEpoch.toString(),
                title: titleController.text,
                description: descController.text,
                dueDate: dueDate ?? DateTime.now().add(Duration(days: 7)),
                totalMarks: 100,
                assignedDate: DateTime.now(),
              );
              DataManager.addAssignment(assignment);
              
              // Send notifications to all students
              for (var student in DataManager.students) {
                notificationService.showNotification(
                  'New Assignment Posted 📚',
                  '${assignment.title} has been assigned. Due: ${DateFormat('MMM dd').format(assignment.dueDate)}',
                  id: student.id.hashCode,
                );
              }
              
              Navigator.pop(context);
              setState(() {});
              ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text('Assignment created!')));
            },
            child: Text('Create'),
          ),
        ],
      ),
    );
  }
}


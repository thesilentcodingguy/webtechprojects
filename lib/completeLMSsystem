}

final FlutterLocalNotificationsPlugin flutterLocalNotificationsPlugin =
    FlutterLocalNotificationsPlugin();

class NotificationService {
  Future<void> init() async {
    const AndroidInitializationSettings androidSettings =
        AndroidInitializationSettings('@mipmap/ic_launcher');

    const InitializationSettings settings =
        InitializationSettings(android: androidSettings);

    await flutterLocalNotificationsPlugin.initialize(settings);
  }

  Future<void> showNotification(
      String title, String body, {int id = 0}) async {
    const AndroidNotificationDetails androidDetails =
        AndroidNotificationDetails(
      'lms_channel',
      'Learning Management System',
      importance: Importance.max,
      priority: Priority.high,
      channelDescription: 'Notifications for assignments, announcements, and messages',
    );

    const NotificationDetails details =
        NotificationDetails(android: androidDetails);

    await flutterLocalNotificationsPlugin.show(
      id,
      title,
      body,
      details,
    );
  }

  Future<void> showScheduledNotification(
      String title, String body, DateTime scheduledTime, int id) async {
    const AndroidNotificationDetails androidDetails =
        AndroidNotificationDetails(
      'scheduled_channel',
      'Scheduled Notifications',
      importance: Importance.high,
      priority: Priority.high,
    );

    const NotificationDetails details =
        NotificationDetails(android: androidDetails);

    await flutterLocalNotificationsPlugin.schedule(
      id,
      title,
      body,
      scheduledTime,
      details,
    );
  }
}

// Models
class Student {
  final String id;
  final String name;
  final String email;
  final String phone;
  final DateTime enrollmentDate;
  double attendance;
  List<String> achievements;
  Map<String, bool> assignmentsStatus;

  Student({
    required this.id,
    required this.name,
    required this.email,
    required this.phone,
    required this.enrollmentDate,
    this.attendance = 0,
    this.achievements = const [],
    this.assignmentsStatus = const {},
  });

  int get age => DateTime.now().difference(enrollmentDate).inDays ~/ 365;
}

class Assignment {
  final String id;
  final String title;
  final String description;
  final DateTime dueDate;
  final int totalMarks;
  final DateTime assignedDate;
  Map<String, int> marks; // studentId -> marks

  Assignment({
    required this.id,
    required this.title,
    required this.description,
    required this.dueDate,
    required this.totalMarks,
    required this.assignedDate,
    this.marks = const {},
  });

  bool isOverdue() => DateTime.now().isAfter(dueDate);
}

class Announcement {
  final String id;
  final String title;
  final String content;
  final DateTime date;
  final List<String> attachments;

  Announcement({
    required this.id,
    required this.title,
    required this.content,
    required this.date,
    this.attachments = const [],
  });
}

class Message {
  final String id;
  final String fromId; // teacher id or student id
  final String toId;
  final String content;
  final DateTime timestamp;
  final bool isRead;
  final String type; // 'teacher_to_all', 'teacher_to_student', 'student_to_teacher'

  Message({
    required this.id,
    required this.fromId,
    required this.toId,
    required this.content,
    required this.timestamp,
    this.isRead = false,
    required this.type,
  });
}

class Course {
  final String id;
  final String name;
  final String code;
  final String teacherId;
  List<String> studentIds;
  List<Assignment> assignments;
  List<Announcement> announcements;
  String schedule;

  Course({
    required this.id,
    required this.name,
    required this.code,
    required this.teacherId,
    this.studentIds = const [],
    this.assignments = const [],
    this.announcements = const [],
    this.schedule = 'TBA',
  });
}

